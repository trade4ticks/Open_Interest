# --- Postgres (VPS) ----------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=open_interest
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio

# --- ThetaData ---------------------------------------------------------------
# Same primary terminal as the SPX project (Tailscale-reachable on the VPS).
THETADATA_BASE_URL=http://100.76.94.99:25503

# --- Parquet storage for raw OI ---------------------------------------------
# Daily OI rows are written to {OI_RAW_DIR}/{ticker}/{year}.parquet.
# Default is `data/oi_raw` relative to the project root.
OI_RAW_DIR=data/oi_raw

# --- OI surface filtering (legacy; surface table is no longer populated) -----
# Kept here so init_db.py and the existing surface-based views keep working
# against the frozen historical snapshot. Not used by the new parquet pipeline.
OI_MIN                = 100      # drop strikes with open_interest below this
OI_MAX_DTE            = 365      # drop expirations more than this many days out
OI_MAX_MONEYNESS      = 0.50     # drop strikes more than this far from spot (|K/S - 1|)
