# --- Postgres (VPS) ----------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=open_interest
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio

# --- ThetaData ---------------------------------------------------------------
# Same primary terminal as the SPX project (Tailscale-reachable on the VPS).
THETADATA_BASE_URL=http://100.76.94.99:25503

# --- OI surface filtering (used by fetch_oi.py to populate option_oi_surface) -
# Rows from option_oi_raw are kept in option_oi_surface only if they pass ALL
# of these. Tune freely — the goal is "let AI see the meaningful clusters".
OI_MIN                = 100      # drop strikes with open_interest below this
OI_MAX_DTE            = 365      # drop expirations more than this many days out
OI_MAX_MONEYNESS      = 0.50     # drop strikes more than this far from spot (|K/S - 1|)
